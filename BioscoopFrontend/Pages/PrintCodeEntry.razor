@page "/print-code"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<style>
    .ticket-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .ticket {
        background: white;
        border-radius: 16px;
        padding: 30px;
        max-width: 480px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .ticket-table {
        width: 100%;
        text-align: left;
        margin: 15px 0;
    }
    .ticket-table th {
        padding: 6px 10px;
        color: #666;
        font-weight: 600;
        width: 100px;
    }
    .ticket-table td {
        padding: 6px 10px;
    }
    .ticket-barcode {
        font-family: 'Libre Barcode 128', monospace;
        font-size: 2.5rem;
        letter-spacing: 2px;
    }
    .code-input {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 6px;
        text-align: center;
        text-transform: uppercase;
        border: 3px solid #dee2e6;
        border-radius: 12px;
        padding: 14px;
        width: 100%;
        font-family: monospace;
    }
    .code-input:focus {
        border-color: #667eea;
        outline: none;
        box-shadow: 0 0 0 3px rgba(102,126,234,0.2);
    }
    @@media print {
        .no-print { display: none !important; }
        .ticket-overlay { background: white; }
        .ticket { box-shadow: none; max-width: 100%; }
    }
</style>

<div class="header-bar d-flex justify-content-between align-items-center p-3 border-2">
    <h3 class="text-uppercase mb-0 fw-bold">Ticket afdrukken</h3>
    <button class="btn btn-outline-secondary" @onclick="GoBack">
        <span>&larr;</span>
    </button>
</div>

<div class="px-3 mt-4" style="max-width: 480px; margin: 0 auto;">
    <p class="text-muted mb-3">Voer de code in die je thuis hebt ontvangen.</p>

    <input class="code-input mb-3"
           @bind="inputCode"
           @bind:event="oninput"
           placeholder="bijv. A1B2C3"
           maxlength="10" />

    @if (errorMessage != null)
    {
        <div class="alert alert-danger py-2">@errorMessage</div>
    }

    <button class="btn btn-dark w-100 py-2 fw-bold"
            disabled="@(string.IsNullOrWhiteSpace(inputCode) || isLoading)"
            @onclick="LookupCode">
        @if (isLoading) { <span>Zoeken...</span> } else { <span>Zoek ticket &rarr;</span> }
    </button>
</div>

@* ── Ticketscherm ── *@
@if (showTicketOverlay && reservation != null)
{
    <div class="ticket-overlay" @onclick="CloseTicket">
        <div class="ticket" @onclick:stopPropagation style="border: 3px dashed #1b6ec2;">

            <div style="text-align: left; margin-bottom: 15px;">
                <h3 style="margin: 0 0 4px 0; color: #1a1a2e;">CINEMA TICKET</h3>
                <p style="margin: 0; color: #666; font-size: 0.9rem;">Bewaar dit ticket goed</p>
            </div>

            <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                <h4 style="margin: 0; font-size: 1.4rem;">@reservation.MovieTitle</h4>
            </div>

            <table class="ticket-table">
                <tr>
                    <th>Datum</th>
                    <td><strong>@reservation.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</strong></td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td><strong style="font-size: 1.3rem; color: #e74c3c;">@reservation.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</strong></td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 8px 20px; border-radius: 25px; font-weight: bold; font-size: 1.1rem;">
                            ZAAL @reservation.HallNumber
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Stoelen</th>
                    <td>
                        <strong>
                            @foreach (var seat in reservation.Seats)
                            {
                                <span class="badge bg-secondary me-1">Rij @seat.RowLabel - Stoel @seat.SeatNumber</span>
                            }
                        </strong>
                    </td>
                </tr>
                <tr>
                    <th>Bedrag</th>
                    <td><strong>@reservation.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</strong></td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td><span style="color: #27ae60; font-weight: bold;">BETAALD</span></td>
                </tr>
            </table>

            <div style="background: #f8f9fa; border: 2px solid #dee2e6; border-radius: 8px; padding: 15px; margin: 15px 0; text-align: center;">
                <p style="margin: 0 0 5px 0; color: #666; font-size: 0.85rem;">TICKETCODE</p>
                <p style="margin: 0; font-size: 1.8rem; font-weight: bold; letter-spacing: 4px; font-family: monospace;">@reservation.PrintCode</p>
            </div>

            <div style="border-top: 2px dashed #ccc; border-bottom: 2px dashed #ccc; padding: 15px 0; margin: 15px 0;">
                <p class="ticket-barcode" style="margin: 0;">||||| |||| | || ||| || |||| |||||</p>
                <p style="margin: 5px 0 0 0; font-size: 0.75rem; color: #999;">Toon dit ticket bij de ingang</p>
            </div>

            <div class="no-print mt-3 d-flex gap-2 justify-content-center">
                <button class="btn btn-success btn-lg" @onclick="PrintTicket" style="padding: 12px 30px;">
                    Afdrukken
                </button>
                <button class="btn btn-outline-secondary btn-lg" @onclick="CloseTicket">
                    Sluiten
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string? inputCode;
    private bool isLoading;
    private string? errorMessage;
    private bool showTicketOverlay;
    private ReservationGroupResponseDto? reservation;

    private async Task LookupCode()
    {
        if (string.IsNullOrWhiteSpace(inputCode)) return;

        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.GetAsync($"api/reservations/by-code/{inputCode.Trim().ToUpper()}");

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = "Code niet gevonden. Controleer de code en probeer opnieuw.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Er ging iets mis. Probeer opnieuw.";
                return;
            }

            reservation = await response.Content.ReadFromJsonAsync<ReservationGroupResponseDto>();
            showTicketOverlay = true;
        }
        catch (Exception)
        {
            errorMessage = "Verbinding mislukt. Probeer opnieuw.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CloseTicket()
    {
        showTicketOverlay = false;
        reservation = null;
        inputCode = null;
    }

    private async Task PrintTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/films");
    }
}
