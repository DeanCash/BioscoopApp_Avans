@page "/admin-panel/mailing"
@using System.Net.Http.Json
@using BioscoopFrontend.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthService AuthService

<PageTitle>Nieuwsbrief</PageTitle>

<div class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <h1>NIEUWSBRIEF</h1>
            <p>Verstuur mails naar alle aangemelde abonnees</p>
        </div>
        <div class="header-actions">
            <button class="back-button" @onclick="GoBack">&#8592;</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="mail-alert mail-alert-error">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="mail-alert mail-alert-success">@successMessage</div>
    }

    <section class="dashboard-section">
        <div class="section-header">
            <h2>Mail versturen</h2>
        </div>

        <div class="mail-form">
            <div class="mail-field">
                <label class="mail-label">Onderwerp</label>
                <input class="mail-input"
                       type="text"
                       placeholder="Onderwerp van de mail"
                       @bind="mailSubject"
                       @bind:event="oninput"
                       disabled="@isSending" />
            </div>

            <div class="mail-field">
                <label class="mail-label">Bericht</label>
                <textarea class="mail-textarea"
                          rows="6"
                          placeholder="Schrijf hier je bericht..."
                          @bind="mailBody"
                          @bind:event="oninput"
                          disabled="@isSending"></textarea>
            </div>

            <button class="send-button"
                    @onclick="SendMailAsync"
                    disabled="@(isSending || string.IsNullOrWhiteSpace(mailSubject) || string.IsNullOrWhiteSpace(mailBody))">
                @if (isSending)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Versturen...</span>
                }
                else
                {
                    <span>Versturen naar @subscribers.Count abonnee(s)</span>
                }
            </button>
        </div>
    </section>

    <section class="dashboard-section">
        <div class="section-header">
            <h2>Abonnees (@subscribers.Count)</h2>
            <button class="add-button" @onclick="LoadSubscribersAsync">Vernieuwen</button>
        </div>

        <div class="list-box">
            @if (isLoading)
            {
                <div class="empty-row">
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    Laden...
                </div>
            }
            else if (subscribers.Count == 0)
            {
                <div class="empty-row">Nog geen abonnees aangemeld.</div>
            }
            else
            {
                @foreach (var sub in subscribers)
                {
                    <div class="list-row">
                        <div class="row-text">
                            @sub.Email
                            <span class="sub-date">&#8212; @sub.SubscribedAtUtc.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</span>
                        </div>
                        <div class="row-actions">
                            <button class="delete-button" @onclick="() => OpenDeleteModal(sub)">Delete</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    @if (showDeleteModal && deleteTarget != null)
    {
        <div class="modal-backdrop">
            <div class="modal-box">
                <h3>Abonnee verwijderen</h3>
                <p>Weet je zeker dat je <strong>@deleteTarget.Email</strong> wilt verwijderen?</p>
                <div class="admin-actions">
                    <button class="danger-button" @onclick="ConfirmDeleteAsync">Verwijderen</button>
                    <button class="secondary-button" @onclick="CloseDeleteModal">Annuleren</button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .mail-alert {
        border-radius: 8px;
        padding: 11px 16px;
        margin-bottom: 18px;
        font-size: 14px;
        font-weight: 500;
    }

    .mail-alert-error {
        background: rgba(229, 62, 62, 0.08);
        border: 1px solid rgba(229, 62, 62, 0.25);
        color: #c53030;
    }

    .mail-alert-success {
        background: rgba(56, 161, 105, 0.1);
        border: 1px solid rgba(56, 161, 105, 0.3);
        color: #276749;
    }

    .mail-form {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .mail-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .mail-label {
        font-size: 13px;
        font-weight: 700;
        color: #1a2040;
    }

    .mail-input,
    .mail-textarea {
        border: 1px solid #d1d9ee;
        border-radius: 8px;
        padding: 9px 13px;
        font-size: 14px;
        font-family: inherit;
        color: #1a2040;
        outline: none;
        transition: border-color 0.15s;
    }

    .mail-input:focus,
    .mail-textarea:focus {
        border-color: #4f6ef7;
    }

    .mail-textarea {
        resize: vertical;
    }

    .send-button {
        height: 40px;
        padding: 0 22px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        align-self: flex-start;
        font-family: inherit;
        transition: opacity 0.15s;
    }

    .send-button:hover:not(:disabled) {
        opacity: 0.88;
    }

    .send-button:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .sub-date {
        font-size: 12px;
        color: #7a85a3;
        margin-left: 4px;
    }
</style>

@code {
    private List<SubscriberDto> subscribers = new();
    private bool isLoading = true;
    private bool isSending;
    private string? errorMessage;
    private string? successMessage;
    private string mailSubject = "";
    private string mailBody = "";

    private bool showDeleteModal;
    private SubscriberDto? deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        var role = await AuthService.GetRoleAsync();
        if (role != "Manager")
        {
            Nav.NavigateTo("/admin-panel/login", forceLoad: true);
            return;
        }

        await LoadSubscribersAsync();
    }

    private async Task LoadSubscribersAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await Http.GetFromJsonAsync<List<SubscriberDto>>("api/newsletter/subscribers");
            subscribers = result ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kon abonnees niet ophalen: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SendMailAsync()
    {
        isSending = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/newsletter/send", new
            {
                Subject = mailSubject.Trim(),
                HtmlBody = mailBody
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<MessageResult>();
                successMessage = result?.Message ?? "Mail verstuurd!";
                mailSubject = "";
                mailBody = "";
            }
            else
            {
                var err = await response.Content.ReadFromJsonAsync<MessageResult>();
                errorMessage = err?.Message ?? "Er is iets misgegaan.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout: {ex.Message}";
        }
        finally
        {
            isSending = false;
        }
    }

    private void OpenDeleteModal(SubscriberDto sub)
    {
        deleteTarget = sub;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        deleteTarget = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (deleteTarget is null) return;
        try
        {
            var response = await Http.DeleteAsync($"api/newsletter/subscribers/{deleteTarget.Id}");
            if (response.IsSuccessStatusCode)
            {
                subscribers.Remove(deleteTarget);
                successMessage = $"{deleteTarget.Email} is verwijderd.";
            }
            else
            {
                errorMessage = "Verwijderen mislukt.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fout: {ex.Message}";
        }
        finally
        {
            CloseDeleteModal();
        }
    }

    private void GoBack() => Nav.NavigateTo("/admin-panel/manager");

    private class SubscriberDto
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = "";
        public DateTimeOffset SubscribedAtUtc { get; set; }
    }

    private class MessageResult
    {
        public string? Message { get; set; }
    }
}
