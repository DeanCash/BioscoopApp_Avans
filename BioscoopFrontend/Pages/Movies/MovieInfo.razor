@page "/kiosk/MovieInfo/{MovieId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject LanguageService Lang
@using BioscoopFrontend.Services

<PageTitle>@(movie?.Title ?? Lang.T("FilmInfo"))</PageTitle>

<style>
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 30px 0 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1rem;
    }
    .btn-back {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(255,255,255,0.2);
        color: white;
    }
    .movie-detail-card {
        display: flex;
        gap: 0;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        background: white;
    }
    .image-container {
        width: 50%;
        flex-shrink: 0;
    }
    .movie-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .image-placeholder {
        width: 100%;
        height: 100%;
        min-height: 400px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .film-icon {
        font-size: 4rem;
        opacity: 0.8;
    }
    .info-section {
        width: 50%;
        padding: 30px;
        overflow-y: auto;
    }
    .info-section h4 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 20px;
    }
    .info-field {
        background: #f8f9fa;
        border: none !important;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 12px;
    }
    .info-label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #667eea;
        margin-bottom: 4px;
    }
    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a2e;
        margin: 0;
    }
    .info-value.description {
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.6;
    }
    .btn-choose {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 16px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        width: 100%;
        margin-top: 24px;
        transition: box-shadow 0.2s;
        display: block;
        text-align: center;
        text-decoration: none;
    }
    .btn-choose:hover {
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        color: white;
    }
    @@media (max-width: 768px) {
        .movie-detail-card {
            flex-direction: column;
        }
        .image-container, .info-section {
            width: 100%;
        }
        .image-placeholder {
            min-height: 300px;
        }
    }
</style>

<div class="page-header">
    <button class="btn btn-back mb-3" @onclick="GoBack">
        <span>&larr;</span> @Lang.T("Back")
    </button>
    <h1>@Lang.T("FilmInformation")</h1>
    <p>@Lang.T("ViewFilmDetails")</p>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger mx-3">@errorMessage</div>
}
else if (movie == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">@Lang.T("Loading")</span>
        </div>
        <p class="mt-3 text-muted">@Lang.T("LoadingMovie")</p>
    </div>
}
else
{
    <div class="container">
        <div class="movie-detail-card">
            <div class="image-container">
                @if (!string.IsNullOrEmpty(movie.ImageUrl))
                {
                    <img src="@movie.ImageUrl" alt="@movie.Title" class="movie-poster" />
                }
                else
                {
                    <div class="image-placeholder">
                        <span class="film-icon">&#127902;</span>
                    </div>
                }
            </div>

            <div class="info-section">
                <h4>@movie.Title</h4>

                <div class="info-field">
                    <span class="info-label">@Lang.T("Genre")</span>
                    <p class="info-value">@movie.Genre</p>
                </div>

                <div class="info-field">
                    <span class="info-label">@Lang.T("Duration")</span>
                    <p class="info-value">@movie.DurationMinutes @Lang.T("Minutes")</p>
                </div>

                <div class="info-field">
                    <span class="info-label">@Lang.T("Age")</span>
                    <p class="info-value">@movie.Age+</p>
                </div>

                <div class="info-field">
                    <span class="info-label">@Lang.T("Description")</span>
                    <p class="info-value description">@movie.Description</p>
                </div>
            </div>
        </div>

        <a href="/kiosk/Showing/@MovieId" class="btn-choose">
            @Lang.T("ChooseShowingArrow")
        </a>
    </div>
}

@code {
    [Parameter]
    public Guid MovieId { get; set; }

    private MovieDetailDto? movie;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movie = await Http.GetFromJsonAsync<MovieDetailDto>($"api/movies/{MovieId}");
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("MovieCouldNotBeLoaded");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/kiosk/home");
    }
}