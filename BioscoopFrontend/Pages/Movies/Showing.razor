@page "/Showing/{MovieId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="header-bar d-flex justify-content-between align-items-center p-3 border-2">
    <div>
        <h3 class="text-uppercase mb-0 fw-bold">Choose Showing</h3>
        @if (movieTitle != null)
        {
            <small class="text-muted">@movieTitle</small>
        }
    </div>
    <button class="btn btn-outline-secondary" @onclick="GoBack">
        <span>&larr;</span>
    </button>
</div>

@if (errorMessage != null)
{
    <p class="text-danger mt-3">@errorMessage</p>
}
else if (screenings == null)
{
    <p class="mt-3"><em>Voorstellingen laden...</em></p>
}
else if (!screenings.Any())
{
    <p class="mt-3"><em>Geen voorstellingen gevonden voor deze film.</em></p>
}
else
{
    <div class="showings-grid mt-3">
        @foreach (var screening in screenings)
        {
            <div class="showing-card border border-2 p-3" @onclick="() => SelectShowing(screening.ScreeningId)">
                <div class="showing-date text-muted mb-2">@FormatDate(screening.StartTimeUtc)</div>

                <div class="d-flex align-items-center mb-1">
                    <span class="showing-time fw-bold">@screening.StartTimeUtc.ToLocalTime().ToString("HH:mm")</span>
                </div>

                <div class="d-flex align-items-center mb-3">
                    <span>Hall @(screening.Hall?.Number)</span>
                </div>

                <div class="seats-info border p-2">
                    @if (availableSeats != null && availableSeats.TryGetValue(screening.ScreeningId, out var count))
                    {
                        <span>@count seats available</span>
                    }
                    else
                    {
                        <span>Loading...</span>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid MovieId { get; set; }

    private List<ScreeningResponseDto>? screenings;
    private Dictionary<Guid, int>? availableSeats;
    private string? movieTitle;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var movieTask = Http.GetFromJsonAsync<MovieDetailDto>($"api/movies/{MovieId}");
            var screeningsTask = Http.GetFromJsonAsync<List<ScreeningResponseDto>>($"api/screenings?movieId={MovieId}");
            var seatsTask = Http.GetFromJsonAsync<Dictionary<Guid, int>>($"api/screenings/available-seats?movieId={MovieId}");

            await Task.WhenAll(movieTask, screeningsTask, seatsTask);

            movieTitle = movieTask.Result?.Title;
            screenings = screeningsTask.Result ?? new();
            availableSeats = seatsTask.Result ?? new();
        }
        catch (HttpRequestException)
        {
            errorMessage = "Voorstellingen konden niet worden geladen.";
        }
    }

    private string FormatDate(DateTimeOffset date)
    {
        var local = date.ToLocalTime();
        var today = DateTimeOffset.Now.Date;

        if (local.Date == today)
            return $"Today - {local:MMMM d}";
        if (local.Date == today.AddDays(1))
            return $"Tomorrow - {local:MMMM d}";

        return local.ToString("dddd - MMMM d");
    }

    private void SelectShowing(Guid screeningId)
    {
        // Navigate to next step (e.g., seat selection)
        Navigation.NavigateTo($"/SelectTickets/{screeningId}");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/MovieInfo/{MovieId}");
    }
}