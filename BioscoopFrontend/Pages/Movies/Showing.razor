@page "/kiosk/Showing/{MovieId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject LanguageService Lang
@using BioscoopFrontend.Services

<PageTitle>@Lang.T("Showings")</PageTitle>

<style>
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 30px 0 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1rem;
    }
    .btn-back {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(255,255,255,0.2);
        color: white;
    }
    .showing-card {
        background: white;
        border: none;
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        cursor: pointer;
        transition: box-shadow 0.2s;
    }
    .showing-card:hover {
        box-shadow: 0 6px 24px rgba(0,0,0,0.12);
    }
    .showing-date {
        font-size: 0.9rem;
        color: #888;
        text-transform: capitalize;
    }
    .showing-time {
        font-size: 1.8rem;
        font-weight: 800;
        color: #1a1a2e;
        letter-spacing: -1px;
    }
    .hall-badge {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 10px 22px;
        border-radius: 25px;
        font-weight: 700;
        font-size: 0.95rem;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }
    .seats-badge {
        font-size: 0.9rem;
        color: #555;
        margin-top: 6px;
    }
    .seats-available { color: #2ecc71; font-weight: 700; }
    .seats-limited { color: #f39c12; font-weight: 700; }
    .seats-full { color: #e74c3c; font-weight: 700; }
    .btn-book {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
        border: none;
        color: white;
        padding: 12px 28px;
        border-radius: 25px;
        font-weight: 700;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 15px rgba(238, 90, 36, 0.3);
    }
    .btn-book:hover {
        box-shadow: 0 8px 25px rgba(238, 90, 36, 0.5);
        color: white;
    }
    .no-screenings {
        text-align: center;
        padding: 60px 40px;
        background: #f8f9fa;
        border-radius: 16px;
        color: #888;
    }
    .no-screenings h4 {
        color: #1a1a2e;
        margin-bottom: 10px;
    }
    @@media (max-width: 768px) {
        .showing-card {
            flex-direction: column;
            gap: 16px;
            text-align: center;
        }
    }
</style>

<div class="page-header">
    <button class="btn btn-back mb-3" @onclick="GoBack">
        <span>&larr;</span> @Lang.T("Back")
    </button>
    <h1>@Lang.T("ChooseAShowing")</h1>
    @if (movieTitle != null)
    {
        <p>@movieTitle</p>
    }
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger mx-3">@errorMessage</div>
}
else if (screenings == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">@Lang.T("Loading")</span>
        </div>
        <p class="mt-3 text-muted">@Lang.T("LoadingShowings")</p>
    </div>
}
else if (!screenings.Any())
{
    <div class="container">
        <div class="no-screenings">
            <h4>@Lang.T("NoShowingsFound")</h4>
            <p>@Lang.T("NoShowingsPlanned")</p>
        </div>
    </div>
}
else
{
    <div class="container">
        @foreach (var screening in screenings)
        {
            <div class="showing-card" @onclick="() => SelectShowing(screening.ScreeningId)">
                <div>
                    <div class="showing-date">@FormatDate(screening.StartTimeUtc)</div>
                    <div class="showing-time">@screening.StartTimeUtc.ToLocalTime().ToString("HH:mm")</div>
                </div>
                <div class="text-center">
                    <span class="hall-badge">@Lang.T("Hall") @(screening.Hall?.Number)</span>
                    <div class="seats-badge">
                        @if (availableSeats != null && availableSeats.TryGetValue(screening.ScreeningId, out var count))
                        {
                            var seatsClass = count > 20 ? "seats-available" : count > 5 ? "seats-limited" : "seats-full";
                            <span class="@seatsClass">@count</span> <span>@Lang.T("SeatsAvailable")</span>
                        }
                        else
                        {
                            <span class="text-muted">@Lang.T("Loading")</span>
                        }
                    </div>
                </div>
                <button class="btn btn-book" disabled="@(availableSeats != null && availableSeats.TryGetValue(screening.ScreeningId, out var c) && c == 0)">
                    @Lang.T("BookNowArrow")
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid MovieId { get; set; }

    private List<ScreeningResponseDto>? screenings;
    private Dictionary<Guid, int>? availableSeats;
    private string? movieTitle;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var movieTask = Http.GetFromJsonAsync<MovieDetailDto>($"api/movies/{MovieId}");
            var screeningsTask = Http.GetFromJsonAsync<List<ScreeningResponseDto>>($"api/screenings?movieId={MovieId}");
            var seatsTask = Http.GetFromJsonAsync<Dictionary<Guid, int>>($"api/screenings/available-seats?movieId={MovieId}");

            await Task.WhenAll(movieTask, screeningsTask, seatsTask);

            movieTitle = movieTask.Result?.Title;
            screenings = screeningsTask.Result ?? new();
            availableSeats = seatsTask.Result ?? new();
        }
        catch (HttpRequestException)
        {
            errorMessage = Lang.T("ShowingsCouldNotBeLoaded");
        }
    }

    private string FormatDate(DateTimeOffset date)
    {
        var local = date.ToLocalTime();
        var today = DateTimeOffset.Now.Date;

        if (local.Date == today)
            return $"{Lang.T("Today")} - {local:d MMMM}";
        if (local.Date == today.AddDays(1))
            return $"{Lang.T("Tomorrow")} - {local:d MMMM}";

        return local.ToString("dddd - d MMMM");
    }

    private void SelectShowing(Guid screeningId)
    {
        Navigation.NavigateTo($"/kiosk/SelectTickets/{screeningId}");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/kiosk/MovieInfo/{MovieId}");
    }
}