@page "/SelectTickets/{ScreeningId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<style>
    .ticket-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .ticket {
        background: white;
        border-radius: 16px;
        padding: 30px;
        max-width: 480px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .ticket-table {
        width: 100%;
        text-align: left;
        margin: 15px 0;
    }
    .ticket-table th {
        padding: 6px 10px;
        color: #666;
        font-weight: 600;
        width: 100px;
    }
    .ticket-table td {
        padding: 6px 10px;
    }
    .ticket-barcode {
        font-family: 'Libre Barcode 128', monospace;
        font-size: 2.5rem;
        letter-spacing: 2px;
    }
    @@media print {
        .no-print { display: none !important; }
        .ticket-overlay { background: white; }
        .ticket { box-shadow: none; max-width: 100%; }
    }
</style>

<div class="header-bar d-flex justify-content-between align-items-center p-3 border-2">
    <div>
        <h3 class="text-uppercase mb-0 fw-bold">Select Tickets</h3>
        @if (screening?.Movie != null)
        {
            <small class="text-muted">@screening.Movie.Title</small>
        }
    </div>
    <button class="btn btn-outline-secondary" @onclick="GoBack">
        <span>&larr;</span>
    </button>
</div>

@if (errorMessage != null)
{
    <p class="text-danger mt-3 px-3">@errorMessage</p>
}
else if (tariffs == null)
{
    <p class="mt-3 px-3"><em>Tarieven laden...</em></p>
}
else
{
    <div class="tickets-container mt-3 px-3">
        @foreach (var tariff in tariffs)
        {
            <div class="tariff-card d-flex justify-content-between align-items-center p-3 mb-2">
                <div>
                    <div class="tariff-name fw-bold">@tariff.DisplayName</div>
                    <div class="tariff-price text-muted">@tariff.Price.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</div>
                </div>
                <div class="counter d-flex align-items-center gap-2">
                    <button class="btn btn-counter" @onclick="() => Decrement(tariff.TariffId)" disabled="@(GetCount(tariff.TariffId) == 0)">−</button>
                    <span class="count-display fw-bold">@GetCount(tariff.TariffId)</span>
                    <button class="btn btn-counter" @onclick="() => Increment(tariff.TariffId)">+</button>
                </div>
            </div>
        }

        @* ── Arrangementen sectie ── *@
        @if (arrangements != null && arrangements.Any())
        {
            <div class="mt-4">
                <h5 class="fw-bold mb-3" style="color: #e74c3c;">Extra's & Arrangementen</h5>

                @foreach (var category in ArrangementsByCategory)
                {
                    <div class="mb-3">
                        <h6 class="text-muted mb-2">@GetCategoryDisplayName(category.Key)</h6>
                        @foreach (var arr in category.Value)
                        {
                            <div class="tariff-card d-flex justify-content-between align-items-center p-3 mb-2" style="background: linear-gradient(135deg, #fff5f5 0%, #fff 100%); border-left: 4px solid #e74c3c;">
                                <div>
                                    <div class="tariff-name fw-bold">@arr.Name</div>
                                    @if (!string.IsNullOrEmpty(arr.Description))
                                    {
                                        <small class="text-muted">@arr.Description</small>
                                    }
                                    <div class="tariff-price" style="color: #e74c3c; font-weight: 600;">@arr.Price.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</div>
                                </div>
                                <div class="counter d-flex align-items-center gap-2">
                                    <button class="btn btn-counter" style="background: #e74c3c; color: white;" @onclick="() => DecrementArrangement(arr.ArrangementId)" disabled="@(GetArrangementCount(arr.ArrangementId) == 0)">−</button>
                                    <span class="count-display fw-bold">@GetArrangementCount(arr.ArrangementId)</span>
                                    <button class="btn btn-counter" style="background: #e74c3c; color: white;" @onclick="() => IncrementArrangement(arr.ArrangementId)">+</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <div class="summary mt-4 p-3">
            <div class="d-flex justify-content-between mb-1">
                <span>Tickets (@TotalTickets)</span>
                <span>@TicketPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</span>
            </div>
            @if (ArrangementPrice > 0)
            {
                <div class="d-flex justify-content-between mb-1" style="color: #e74c3c;">
                    <span>Extra's</span>
                    <span>@ArrangementPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</span>
                </div>
            }
            <hr class="my-2" />
            <div class="d-flex justify-content-between fw-bold fs-5">
                <span>Totaal</span>
                <span>@TotalPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</span>
            </div>
        </div>

        <button class="btn btn-dark w-100 mt-3 py-2 fw-bold" disabled="@(TotalTickets == 0)" @onclick="ShowPayment">
            Doorgaan
        </button>
    </div>
}

@* ── PIN betaalscherm ── *@
@if (showPaymentOverlay)
{
    <div class="ticket-overlay" @onclick="CancelPayment">
        <div class="ticket" @onclick:stopPropagation>
            @if (screening?.Movie != null && !string.IsNullOrEmpty(screening.Movie.ImageUrl))
            {
                <img src="@screening.Movie.ImageUrl" style="width: 120px; border-radius: 8px; margin-bottom: 15px;" alt="@screening.Movie.Title" />
            }
            <div class="ticket-header">
                <h2>PIN Betaling</h2>
            </div>
            <hr />
            <table class="ticket-table">
                <tr>
                    <th>Film</th>
                    <td><strong>@screening?.Movie?.Title</strong></td>
                </tr>
                <tr>
                    <th>Datum</th>
                    <td>@screening?.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td>@screening?.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td><span class="badge bg-primary">Zaal @screening?.Hall?.Number</span></td>
                </tr>
                <tr>
                    <th>Tickets</th>
                    <td>@TotalTickets</td>
                </tr>
                @if (ArrangementPrice > 0)
                {
                    <tr>
                        <th>Extra's</th>
                        <td>
                            @foreach (var arr in arrangements!.Where(a => GetArrangementCount(a.ArrangementId) > 0))
                            {
                                <div>@GetArrangementCount(arr.ArrangementId)x @arr.Name</div>
                            }
                        </td>
                    </tr>
                }
                <tr>
                    <th>Bedrag</th>
                    <td><strong style="font-size: 1.3rem; color: #28a745;">@TotalPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</strong></td>
                </tr>
            </table>
            <hr />
            <div class="alert alert-info text-center py-2 mb-3">
                <small>Alleen PIN-betaling - geen contant geld geaccepteerd</small>
            </div>
            @if (paymentError != null)
            {
                <div class="alert alert-danger py-2">@paymentError</div>
            }
            <div class="no-print d-flex gap-2 justify-content-center">
                <button class="btn btn-success btn-lg" @onclick="ConfirmPinPayment" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span>Verwerken...</span>
                    }
                    else
                    {
                        <span>Betaal met PIN</span>
                    }
                </button>
                <button class="btn btn-outline-secondary" @onclick="CancelPayment" disabled="@isProcessing">
                    Annuleren
                </button>
            </div>
        </div>
    </div>
}

@* ── Ticketscherm (na succesvolle betaling) ── *@
@if (showTicketOverlay && reservation != null)
{
    <div class="ticket-overlay" @onclick="CloseTicket">
        <div class="ticket" @onclick:stopPropagation style="border: 3px dashed #1b6ec2;">
            <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 15px;">
                @if (screening?.Movie != null && !string.IsNullOrEmpty(screening.Movie.ImageUrl))
                {
                    <img src="@screening.Movie.ImageUrl" style="width: 100px; border-radius: 8px; flex-shrink: 0;" alt="@screening.Movie.Title" />
                }
                <div style="text-align: left; flex: 1;">
                    <h3 style="margin: 0 0 5px 0; color: #1a1a2e;">CINEMA TICKET</h3>
                    <p style="margin: 0; color: #666; font-size: 0.9rem;">Bewaar dit ticket goed</p>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                <h4 style="margin: 0; font-size: 1.4rem;">@reservation.MovieTitle</h4>
            </div>

            <table class="ticket-table">
                <tr>
                    <th>Datum</th>
                    <td><strong>@screening?.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</strong></td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td><strong style="font-size: 1.3rem; color: #e74c3c;">@screening?.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</strong></td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 8px 20px; border-radius: 25px; font-weight: bold; font-size: 1.1rem;">
                            ZAAL @reservation.HallNumber
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Stoelen</th>
                    <td>
                        <strong>
                            @foreach (var seat in reservation.Seats)
                            {
                                <span class="badge bg-secondary me-1">Rij @seat.RowLabel - Stoel @seat.SeatNumber</span>
                            }
                        </strong>
                    </td>
                </tr>
                @if (reservation.Arrangements != null && reservation.Arrangements.Any())
                {
                    <tr>
                        <th>Extra's</th>
                        <td>
                            @foreach (var arr in reservation.Arrangements)
                            {
                                <div><span class="badge bg-danger me-1">@arr.Quantity x</span> @arr.Name</div>
                            }
                        </td>
                    </tr>
                }
                <tr>
                    <th>Bedrag</th>
                    <td><strong>@reservation.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</strong></td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td><span style="color: #27ae60; font-weight: bold;">BETAALD (PIN)</span></td>
                </tr>
            </table>

            <div style="background: #f8f9fa; border: 2px solid #dee2e6; border-radius: 8px; padding: 15px; margin: 15px 0; text-align: center;">
                <p style="margin: 0 0 5px 0; color: #666; font-size: 0.85rem;">TICKETCODE</p>
                <p style="margin: 0; font-size: 1.8rem; font-weight: bold; letter-spacing: 4px; font-family: monospace;">@reservation.PrintCode</p>
            </div>

            <div style="border-top: 2px dashed #ccc; border-bottom: 2px dashed #ccc; padding: 15px 0; margin: 15px 0;">
                <p class="ticket-barcode" style="margin: 0;">||||| |||| | || ||| || |||| |||||</p>
                <p style="margin: 5px 0 0 0; font-size: 0.75rem; color: #999;">Toon dit ticket bij de ingang</p>
            </div>

            <div class="no-print mt-3 d-flex gap-2 justify-content-center">
                <button class="btn btn-success btn-lg" @onclick="PrintTicket" style="padding: 12px 30px;">
                    Afdrukken
                </button>
                <button class="btn btn-outline-secondary btn-lg" @onclick="CloseTicket">
                    Sluiten
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid ScreeningId { get; set; }

    private List<TariffDto>? tariffs;
    private List<ArrangementDto>? arrangements;
    private ScreeningResponseDto? screening;
    private ReservationGroupResponseDto? reservation;
    private Dictionary<Guid, int> counts = new();
    private Dictionary<Guid, int> arrangementCounts = new();
    private string? errorMessage;
    private string? paymentError;
    private bool isProcessing;
    private bool showPaymentOverlay;
    private bool showTicketOverlay;

    private int TotalTickets => counts.Values.Sum();
    private decimal TicketPrice => tariffs?.Sum(t => t.Price * GetCount(t.TariffId)) ?? 0;
    private decimal ArrangementPrice => arrangements?.Sum(a => a.Price * GetArrangementCount(a.ArrangementId)) ?? 0;
    private decimal TotalPrice => TicketPrice + ArrangementPrice;

    // Groepeer arrangementen per categorie
    private Dictionary<string, List<ArrangementDto>> ArrangementsByCategory =>
        arrangements?.GroupBy(a => a.Category).ToDictionary(g => g.Key, g => g.ToList()) ?? new();

    private string GetCategoryDisplayName(string category) => category switch
    {
        "Popcorn" => "Popcorn",
        "Drank" => "Drankjes",
        "Snack" => "Snacks",
        "ComboPackage" => "Combo Deals",
        "HorecaSpecial" => "Specials",
        _ => category
    };

    private int GetArrangementCount(Guid id) => arrangementCounts.TryGetValue(id, out var c) ? c : 0;

    private void IncrementArrangement(Guid id)
    {
        arrangementCounts[id] = GetArrangementCount(id) + 1;
    }

    private void DecrementArrangement(Guid id)
    {
        var current = GetArrangementCount(id);
        if (current > 0) arrangementCounts[id] = current - 1;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tariffTask = Http.GetFromJsonAsync<List<TariffDto>>("api/tariffs");
            var screeningTask = Http.GetFromJsonAsync<ScreeningResponseDto>($"api/screenings/{ScreeningId}");
            var arrangementTask = Http.GetFromJsonAsync<List<ArrangementDto>>("api/arrangements");

            await Task.WhenAll(tariffTask, screeningTask, arrangementTask);

            tariffs = tariffTask.Result;
            screening = screeningTask.Result;
            arrangements = arrangementTask.Result;
        }
        catch (HttpRequestException)
        {
            errorMessage = "Gegevens konden niet worden geladen.";
        }
    }

    private int GetCount(Guid tariffId) => counts.TryGetValue(tariffId, out var c) ? c : 0;

    private void Increment(Guid tariffId)
    {
        counts[tariffId] = GetCount(tariffId) + 1;
    }

    private void Decrement(Guid tariffId)
    {
        var current = GetCount(tariffId);
        if (current > 0) counts[tariffId] = current - 1;
    }

    private void ShowPayment()
    {
        if (TotalTickets == 0) return;
        showPaymentOverlay = true;
        paymentError = null;
    }

    private async Task ConfirmPinPayment()
    {
        isProcessing = true;
        paymentError = null;

        try
        {
            // 1. Create reservation (assigns seats, creates orders per seat)
            var request = new
            {
                ScreeningId,
                Tickets = counts
                    .Where(kv => kv.Value > 0)
                    .Select(kv => new { TariffId = kv.Key, Count = kv.Value })
                    .ToList(),
                Arrangements = arrangementCounts
                    .Where(kv => kv.Value > 0)
                    .Select(kv => new { ArrangementId = kv.Key, Quantity = kv.Value })
                    .ToList()
            };

            var response = await Http.PostAsJsonAsync("api/reservations", request);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                paymentError = body.Contains("SOLD_OUT") ? "Uitverkocht! Geen stoelen meer beschikbaar."
                    : body.Contains("NO_ADJACENT") ? "Niet genoeg aaneengesloten stoelen beschikbaar."
                    : "Reservering mislukt. Probeer opnieuw.";
                return;
            }

            reservation = await response.Content.ReadFromJsonAsync<ReservationGroupResponseDto>();

            if (reservation != null)
            {
                // 2. Pay each order (one per seat)
                foreach (var seat in reservation.Seats)
                {
                    await Http.PostAsync($"api/orders/{seat.OrderId}/pay", null);
                }
            }

            showPaymentOverlay = false;
            showTicketOverlay = true;
        }
        catch (Exception)
        {
            paymentError = "Er ging iets mis. Probeer opnieuw.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void CancelPayment()
    {
        showPaymentOverlay = false;
        paymentError = null;
    }

    private void CloseTicket()
    {
        Navigation.NavigateTo("/films");
    }

    private async Task PrintTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }
}
