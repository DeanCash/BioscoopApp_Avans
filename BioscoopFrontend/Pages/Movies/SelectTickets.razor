@page "/kiosk/SelectTickets/{ScreeningId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Tickets Kiezen</PageTitle>

<style>
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 30px 0 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1rem;
    }
    .btn-back {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(255,255,255,0.2);
        color: white;
    }
    .tariff-card {
        background: white;
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 18px 22px;
        margin-bottom: 12px;
        transition: transform 0.2s;
    }
    .tariff-card:hover {
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }
    .tariff-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    .tariff-price {
        font-size: 1rem;
        color: #555;
    }
    .btn-counter {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        font-size: 1.3rem;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;
    }
    .btn-counter:hover:not(:disabled) {
        opacity: 0.85;
    }
    .btn-counter:disabled {
        background: #ddd;
    }
    .count-display {
        width: 36px;
        text-align: center;
        font-size: 1.3rem;
        color: #1a1a2e;
    }
    .summary-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
        margin-top: 20px;
    }
    .btn-pay {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 16px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        width: 100%;
        margin-top: 16px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-pay:hover:not(:disabled) {
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }
    .btn-pay:disabled {
        opacity: 0.5;
    }
    /* Overlays */
    .ticket-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .ticket {
        background: white;
        border-radius: 20px;
        padding: 35px;
        max-width: 480px;
        width: 90%;
        text-align: center;
        box-shadow: 0 25px 80px rgba(0,0,0,0.4);
    }
    .ticket-table {
        width: 100%;
        text-align: left;
        margin: 15px 0;
    }
    .ticket-table th {
        padding: 8px 10px;
        color: #888;
        font-weight: 500;
        width: 100px;
        vertical-align: top;
    }
    .ticket-table td {
        padding: 8px 10px;
        color: #1a1a2e;
    }
    .ticket-barcode {
        font-family: 'Libre Barcode 128', monospace;
        font-size: 2.5rem;
        letter-spacing: 2px;
    }
    .btn-confirm {
        background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        border: none;
        color: white;
        padding: 14px 36px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 1rem;
        transition: transform 0.2s;
    }
    .btn-confirm:hover:not(:disabled) {
        box-shadow: 0 4px 15px rgba(46, 204, 113, 0.4);
        color: white;
    }
    .btn-cancel {
        background: transparent;
        border: 2px solid #ddd;
        color: #666;
        padding: 14px 30px;
        border-radius: 30px;
        font-weight: 600;
    }
    .btn-cancel:hover {
        background: #f8f9fa;
    }
    .btn-print {
        background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        border: none;
        color: white;
        padding: 14px 36px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 1rem;
    }
    @@media print {
        .no-print { display: none !important; }
        .ticket-overlay { background: white; }
        .ticket { box-shadow: none; max-width: 100%; }
    }
</style>

<div class="page-header">
    <button class="btn btn-back mb-3" @onclick="GoBack">
        <span>&larr;</span> Terug
    </button>
    <h1>Tickets Kiezen</h1>
    @if (screening?.Movie != null)
    {
        <p>@screening.Movie.Title</p>
    }
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger mx-3">@errorMessage</div>
}
else if (tariffs == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Laden...</span>
        </div>
        <p class="mt-3 text-muted">Tarieven laden...</p>
    </div>
}
else
{
    <div class="container" style="max-width: 600px;">
        @foreach (var tariff in tariffs)
        {
            <div class="tariff-card d-flex justify-content-between align-items-center">
                <div>
                    <div class="tariff-name">@tariff.DisplayName</div>
                    <div class="tariff-price">@tariff.Price.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</div>
                </div>
                <div class="counter d-flex align-items-center gap-2">
                    <button class="btn btn-counter" @onclick="() => Decrement(tariff.TariffId)" disabled="@(GetCount(tariff.TariffId) == 0)">−</button>
                    <span class="count-display fw-bold">@GetCount(tariff.TariffId)</span>
                    <button class="btn btn-counter" @onclick="() => Increment(tariff.TariffId)">+</button>
                </div>
            </div>
        }

        <div class="summary-box">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Aantal tickets</span>
                <span class="fw-bold">@TotalTickets</span>
            </div>
            <div class="d-flex justify-content-between">
                <span class="fw-bold fs-5">Totaal</span>
                <span class="fw-bold fs-5">@TotalPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</span>
            </div>
        </div>

        <button class="btn btn-pay" disabled="@(TotalTickets == 0)" @onclick="ShowPayment">
            Doorgaan &rarr;
        </button>
    </div>
}

@* -- PIN betaalscherm -- *@
@if (showPaymentOverlay)
{
    <div class="ticket-overlay" @onclick="CancelPayment">
        <div class="ticket" @onclick:stopPropagation>
            @if (screening?.Movie != null && !string.IsNullOrEmpty(screening.Movie.ImageUrl))
            {
                <img src="@screening.Movie.ImageUrl" style="width: 120px; border-radius: 12px; margin-bottom: 15px; box-shadow: 0 8px 25px rgba(0,0,0,0.2);" alt="@screening.Movie.Title" />
            }
            <h2 style="color: #1a1a2e; font-weight: 700;">PIN Betaling</h2>
            <hr style="border-color: #eee; margin: 20px 0;" />
            <table class="ticket-table">
                <tr>
                    <th>Film</th>
                    <td><strong>@screening?.Movie?.Title</strong></td>
                </tr>
                <tr>
                    <th>Datum</th>
                    <td>@screening?.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td>@screening?.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 6px 14px; border-radius: 20px; font-weight: 600; font-size: 0.9rem;">
                            Zaal @screening?.Hall?.Number
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Tickets</th>
                    <td>@TotalTickets</td>
                </tr>
                <tr>
                    <th>Bedrag</th>
                    <td><strong style="font-size: 1.3rem; color: #27ae60;">@TotalPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</strong></td>
                </tr>
            </table>
            <hr style="border-color: #eee; margin: 20px 0;" />
            <div style="background: #e3f2fd; border-radius: 10px; padding: 12px; margin-bottom: 20px;">
                <small style="color: #1976d2;">Alleen PIN-betaling - geen contant geld geaccepteerd</small>
            </div>
            @if (paymentError != null)
            {
                <div class="alert alert-danger py-2">@paymentError</div>
            }
            <div class="no-print d-flex gap-3 justify-content-center">
                <button class="btn btn-confirm" @onclick="ConfirmPinPayment" disabled="@isProcessing">
                    @if (isProcessing) { <span>Verwerken...</span> } else { <span>Betaal met PIN</span> }
                </button>
                <button class="btn btn-cancel" @onclick="CancelPayment" disabled="@isProcessing">
                    Annuleren
                </button>
            </div>
        </div>
    </div>
}

@* -- Ticketscherm (na succesvolle betaling) -- *@
@if (showTicketOverlay && reservation != null)
{
    <div class="ticket-overlay" @onclick="CloseTicket">
        <div class="ticket" @onclick:stopPropagation style="border: 4px dashed #667eea;">
            <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 20px;">
                @if (screening?.Movie != null && !string.IsNullOrEmpty(screening.Movie.ImageUrl))
                {
                    <img src="@screening.Movie.ImageUrl" style="width: 100px; border-radius: 10px; flex-shrink: 0; box-shadow: 0 4px 15px rgba(0,0,0,0.2);" alt="@screening.Movie.Title" />
                }
                <div style="text-align: left; flex: 1;">
                    <h3 style="margin: 0 0 5px 0; color: #1a1a2e; font-weight: 800;">CINEMA TICKET</h3>
                    <p style="margin: 0; color: #666; font-size: 0.9rem;">Bewaar dit ticket goed</p>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 18px; border-radius: 12px; margin-bottom: 20px;">
                <h4 style="margin: 0; font-size: 1.5rem; font-weight: 700;">@reservation.MovieTitle</h4>
            </div>

            <table class="ticket-table">
                <tr>
                    <th>Datum</th>
                    <td><strong>@screening?.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</strong></td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td><strong style="font-size: 1.3rem; color: #e74c3c;">@screening?.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</strong></td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 8px 20px; border-radius: 25px; font-weight: bold; font-size: 1.1rem;">
                            ZAAL @reservation.HallNumber
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Stoelen</th>
                    <td>
                        <strong>
                            @foreach (var seat in reservation.Seats)
                            {
                                <span class="badge" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); margin-right: 4px;">Rij @seat.RowLabel - Stoel @seat.SeatNumber</span>
                            }
                        </strong>
                    </td>
                </tr>
                <tr>
                    <th>Bedrag</th>
                    <td><strong>@reservation.TotalAmount.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</strong></td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td><span style="color: #27ae60; font-weight: bold;">BETAALD (PIN)</span></td>
                </tr>
            </table>

            <div style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border: 2px solid #dee2e6; border-radius: 12px; padding: 20px; margin: 20px 0; text-align: center;">
                <p style="margin: 0 0 8px 0; color: #666; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Ticketcode</p>
                <p style="margin: 0; font-size: 2rem; font-weight: 800; letter-spacing: 6px; font-family: monospace; color: #1a1a2e;">@reservation.PrintCode</p>
            </div>

            <div style="border-top: 3px dashed #ccc; border-bottom: 3px dashed #ccc; padding: 18px 0; margin: 20px 0;">
                <p class="ticket-barcode" style="margin: 0;">||||| |||| | || ||| || |||| |||||</p>
                <p style="margin: 8px 0 0 0; font-size: 0.8rem; color: #999;">Toon dit ticket bij de ingang</p>
            </div>

            <div class="no-print mt-3 d-flex gap-3 justify-content-center">
                <button class="btn btn-print" @onclick="PrintTicket">
                    Afdrukken
                </button>
                <button class="btn btn-cancel" @onclick="CloseTicket">
                    Sluiten
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid ScreeningId { get; set; }

    private List<TariffDto>? tariffs;
    private ScreeningResponseDto? screening;
    private ReservationGroupResponseDto? reservation;
    private Dictionary<Guid, int> counts = new();
    private string? errorMessage;
    private string? paymentError;
    private bool isProcessing;
    private bool showPaymentOverlay;
    private bool showTicketOverlay;

    private int TotalTickets => counts.Values.Sum();
    private decimal TotalPrice => tariffs?.Sum(t => t.Price * GetCount(t.TariffId)) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tariffTask = Http.GetFromJsonAsync<List<TariffDto>>("api/tariffs");
            var screeningTask = Http.GetFromJsonAsync<ScreeningResponseDto>($"api/screenings/{ScreeningId}");

            await Task.WhenAll(tariffTask, screeningTask);

            tariffs = tariffTask.Result;
            screening = screeningTask.Result;
        }
        catch (HttpRequestException)
        {
            errorMessage = "Gegevens konden niet worden geladen.";
        }
    }

    private int GetCount(Guid tariffId) => counts.TryGetValue(tariffId, out var c) ? c : 0;

    private void Increment(Guid tariffId)
    {
        counts[tariffId] = GetCount(tariffId) + 1;
    }

    private void Decrement(Guid tariffId)
    {
        var current = GetCount(tariffId);
        if (current > 0) counts[tariffId] = current - 1;
    }

    private void ShowPayment()
    {
        if (TotalTickets == 0) return;
        showPaymentOverlay = true;
        paymentError = null;
    }

    private async Task ConfirmPinPayment()
    {
        isProcessing = true;
        paymentError = null;

        try
        {
            // 1. Create reservation (assigns seats, creates orders per seat)
            var request = new
            {
                ScreeningId,
                Tickets = counts
                    .Where(kv => kv.Value > 0)
                    .Select(kv => new { TariffId = kv.Key, Count = kv.Value })
                    .ToList()
            };

            var response = await Http.PostAsJsonAsync("api/reservations", request);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                paymentError = body.Contains("SOLD_OUT") ? "Uitverkocht! Geen stoelen meer beschikbaar."
                    : body.Contains("NO_ADJACENT") ? "Niet genoeg aaneengesloten stoelen beschikbaar."
                    : "Reservering mislukt. Probeer opnieuw.";
                return;
            }

            reservation = await response.Content.ReadFromJsonAsync<ReservationGroupResponseDto>();

            if (reservation != null)
            {
                // 2. Pay each order (one per seat)
                foreach (var seat in reservation.Seats)
                {
                    await Http.PostAsync($"api/orders/{seat.OrderId}/pay", null);
                }
            }

            showPaymentOverlay = false;
            showTicketOverlay = true;
        }
        catch (Exception)
        {
            paymentError = "Er ging iets mis. Probeer opnieuw.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void CancelPayment()
    {
        showPaymentOverlay = false;
        paymentError = null;
    }

    private void CloseTicket()
    {
        Navigation.NavigateTo("/kiosk/home");
    }

    private async Task PrintTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }
}