@page "/kiosk/SelectTickets/{ScreeningId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Tickets Kiezen</PageTitle>

<style>
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 30px 0 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1rem;
    }
    .btn-back {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(255,255,255,0.2);
        color: white;
    }
    .tariff-card {
        background: white;
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 18px 22px;
        margin-bottom: 12px;
        transition: transform 0.2s;
    }
    .tariff-card:hover {
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }
    .tariff-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    .tariff-price {
        font-size: 1rem;
        color: #555;
    }
    .btn-counter {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        font-size: 1.3rem;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;
    }
    .btn-counter:hover:not(:disabled) {
        opacity: 0.85;
    }
    .btn-counter:disabled {
        background: #ddd;
    }
    .count-display {
        width: 36px;
        text-align: center;
        font-size: 1.3rem;
        color: #1a1a2e;
    }
    .summary-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
        margin-top: 20px;
    }
    .btn-pay {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 16px;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        width: 100%;
        margin-top: 16px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-pay:hover:not(:disabled) {
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }
    .btn-pay:disabled {
        opacity: 0.5;
    }
    /* Overlays */
    .ticket-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .ticket {
        background: white;
        border-radius: 16px;
        padding: 20px 24px;
        max-width: 380px;
        width: 90%;
        text-align: center;
        box-shadow: 0 25px 80px rgba(0,0,0,0.4);
    }
    .ticket-table {
        width: 100%;
        text-align: left;
        margin: 15px 0;
    }
    .ticket-table th {
        padding: 5px 8px;
        color: #888;
        font-weight: 500;
        width: 80px;
        vertical-align: top;
        font-size: 0.85rem;
    }
    .ticket-table td {
        padding: 5px 8px;
        color: #1a1a2e;
        font-size: 0.9rem;
    }
    .btn-confirm {
        background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        border: none;
        color: white;
        padding: 14px 36px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 1rem;
        transition: transform 0.2s;
    }
    .btn-confirm:hover:not(:disabled) {
        box-shadow: 0 4px 15px rgba(46, 204, 113, 0.4);
        color: white;
    }
    .btn-cancel {
        background: transparent;
        border: 2px solid #ddd;
        color: #666;
        padding: 14px 30px;
        border-radius: 30px;
        font-weight: 600;
    }
    .btn-cancel:hover {
        background: #f8f9fa;
    }
    .btn-print {
        background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
        border: none;
        color: white;
        padding: 14px 36px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 1rem;
    }
    @@media print {
        .no-print { display: none !important; }
        .ticket-overlay { background: white; }
        .ticket { box-shadow: none; max-width: 100%; }
    }
</style>

<div class="page-header">
    <button class="btn btn-back mb-3" @onclick="GoBack">
        <span>&larr;</span> Terug
    </button>
    <h1>Tickets Kiezen</h1>
    @if (screening?.Movie != null)
    {
        <p>@screening.Movie.Title</p>
    }
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger mx-3">@errorMessage</div>
}
else if (tariffs == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Laden...</span>
        </div>
        <p class="mt-3 text-muted">Tarieven laden...</p>
    </div>
}
else
{
    <div class="container" style="max-width: 600px;">
        @foreach (var tariff in tariffs)
        {
            <div class="tariff-card d-flex justify-content-between align-items-center">
                <div>
                    <div class="tariff-name">@tariff.DisplayName</div>
                    <div class="tariff-price">@tariff.Price.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</div>
                </div>
                <div class="counter d-flex align-items-center gap-2">
                    <button class="btn btn-counter" @onclick="() => Decrement(tariff.TariffId)" disabled="@(GetCount(tariff.TariffId) == 0)">−</button>
                    <span class="count-display fw-bold">@GetCount(tariff.TariffId)</span>
                    <button class="btn btn-counter" @onclick="() => Increment(tariff.TariffId)">+</button>
                </div>
            </div>
        }

        <div class="summary-box">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Aantal tickets</span>
                <span class="fw-bold">@TotalTickets</span>
            </div>
            <div class="d-flex justify-content-between">
                <span class="fw-bold fs-5">Totaal</span>
                <span class="fw-bold fs-5">@TotalPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</span>
            </div>
        </div>

        <button class="btn btn-pay" disabled="@(TotalTickets == 0)" @onclick="ShowPayment">
            Doorgaan &rarr;
        </button>
    </div>
}

@* -- Stripe betaalscherm (overzicht voor doorsturen) -- *@
@if (showPaymentOverlay)
{
    <div class="ticket-overlay" @onclick="CancelPayment">
        <div class="ticket" @onclick:stopPropagation>
            <h2 style="color: #1a1a2e; font-weight: 700; font-size: 1.3rem; margin-bottom: 12px;">Bestelling bevestigen</h2>
            <hr style="border-color: #eee; margin: 10px 0;" />
            <table class="ticket-table">
                <tr>
                    <th>Film</th>
                    <td><strong>@screening?.Movie?.Title</strong></td>
                </tr>
                <tr>
                    <th>Datum</th>
                    <td>@screening?.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td>@screening?.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 6px 14px; border-radius: 20px; font-weight: 600; font-size: 0.9rem;">
                            Zaal @screening?.Hall?.Number
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Tickets</th>
                    <td>@TotalTickets</td>
                </tr>
                <tr>
                    <th>Bedrag</th>
                    <td><strong style="font-size: 1.3rem; color: #27ae60;">@TotalPrice.ToString("C2", new System.Globalization.CultureInfo("nl-NL"))</strong></td>
                </tr>
            </table>
            <hr style="border-color: #eee; margin: 10px 0;" />
            <div style="background: #e8f5e9; border-radius: 8px; padding: 8px 12px; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; justify-content: center;">
                <img src="https://upload.wikimedia.org/wikipedia/commons/b/ba/Stripe_Logo%2C_revised_2016.svg" style="height: 24px;" alt="Stripe" />
                <small style="color: #2e7d32;">Veilig betalen via Stripe</small>
            </div>
            @if (paymentError != null)
            {
                <div class="alert alert-danger py-2">@paymentError</div>
            }
            <div class="no-print d-flex gap-3 justify-content-center">
                <button class="btn btn-confirm" @onclick="GoToStripePayment" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span>Doorsturen naar Stripe...</span>
                    }
                    else
                    {
                        <span>Betaal via Stripe &rarr;</span>
                    }
                </button>
                <button class="btn btn-cancel" @onclick="CancelPayment" disabled="@isProcessing">
                    Annuleren
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid ScreeningId { get; set; }

    private List<TariffDto>? tariffs;
    private ScreeningResponseDto? screening;
    private ReservationGroupResponseDto? reservation;
    private Dictionary<Guid, int> counts = new();
    private string? errorMessage;
    private string? paymentError;
    private bool isProcessing;
    private bool showPaymentOverlay;

    private int TotalTickets => counts.Values.Sum();
    private decimal TotalPrice => tariffs?.Sum(t => t.Price * GetCount(t.TariffId)) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tariffTask = Http.GetFromJsonAsync<List<TariffDto>>("api/tariffs");
            var screeningTask = Http.GetFromJsonAsync<ScreeningResponseDto>($"api/screenings/{ScreeningId}");

            await Task.WhenAll(tariffTask, screeningTask);

            tariffs = tariffTask.Result;
            screening = screeningTask.Result;
        }
        catch (HttpRequestException)
        {
            errorMessage = "Gegevens konden niet worden geladen.";
        }
    }

    private int GetCount(Guid tariffId) => counts.TryGetValue(tariffId, out var c) ? c : 0;

    private void Increment(Guid tariffId)
    {
        counts[tariffId] = GetCount(tariffId) + 1;
    }

    private void Decrement(Guid tariffId)
    {
        var current = GetCount(tariffId);
        if (current > 0) counts[tariffId] = current - 1;
    }

    private void ShowPayment()
    {
        if (TotalTickets == 0) return;
        showPaymentOverlay = true;
        paymentError = null;
    }

    private async Task GoToStripePayment()
    {
        isProcessing = true;
        paymentError = null;

        try
        {
            // 1. Reservering aanmaken (stoelen toewijzen, orders per stoel)
            var reservationRequest = new
            {
                ScreeningId,
                Tickets = counts
                    .Where(kv => kv.Value > 0)
                    .Select(kv => new { TariffId = kv.Key, Count = kv.Value })
                    .ToList()
            };

            var reservationResponse = await Http.PostAsJsonAsync("api/reservations", reservationRequest);

            if (!reservationResponse.IsSuccessStatusCode)
            {
                var body = await reservationResponse.Content.ReadAsStringAsync();
                paymentError = body.Contains("SOLD_OUT") ? "Uitverkocht! Geen stoelen meer beschikbaar."
                    : body.Contains("NO_ADJACENT") ? "Niet genoeg aaneengesloten stoelen beschikbaar."
                    : "Reservering mislukt. Probeer opnieuw.";
                return;
            }

            reservation = await reservationResponse.Content.ReadFromJsonAsync<ReservationGroupResponseDto>();
            if (reservation == null) return;

            // 2. Stripe Checkout sessie aanmaken
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var checkoutResponse = await Http.PostAsJsonAsync("api/stripe/checkout", new
            {
                reservation.PrintCode,
                ScreeningId,
                FrontendBaseUrl = baseUrl
            });

            if (!checkoutResponse.IsSuccessStatusCode)
            {
                paymentError = "Betaling kon niet worden gestart. Probeer opnieuw.";
                return;
            }

            var result = await checkoutResponse.Content.ReadFromJsonAsync<CheckoutUrlResponse>();
            if (result?.Url == null) return;

            // 3. Doorsturen naar Stripe betaalpagina
            Navigation.NavigateTo(result.Url, forceLoad: true);
        }
        catch (Exception)
        {
            paymentError = "Er ging iets mis. Probeer opnieuw.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private record CheckoutUrlResponse(string Url);

    private void CancelPayment()
    {
        showPaymentOverlay = false;
        paymentError = null;
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }
}