@page "/website/showing/{MovieId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Kies Vertoning</PageTitle>

<style>
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 6px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1rem;
    }
    .showing-card {
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .showing-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    }
    .showing-time {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    .showing-date {
        font-size: 0.9rem;
        color: #888;
        text-transform: capitalize;
    }
    .badge-hall {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .seats-badge {
        background: #e8f5e9;
        color: #2e7d32;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .btn-back {
        background: transparent;
        border: 2px solid rgba(255,255,255,0.5);
        color: white;
        border-radius: 25px;
        padding: 6px 18px;
        font-size: 0.9rem;
    }
    .btn-back:hover {
        background: rgba(255,255,255,0.1);
        color: white;
    }
</style>

<div class="page-header">
    <h1>@(movieTitle ?? "Kies een vertoning")</h1>
    <p>Selecteer een datum en tijdstip</p>
    <button class="btn btn-back mt-2" @onclick="GoBack">&larr; Terug</button>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (screenings == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Vertoningen laden...</p>
    </div>
}
else if (!screenings.Any())
{
    <div class="alert alert-info text-center">
        <h5>Geen vertoningen beschikbaar</h5>
        <p>Er zijn momenteel geen vertoningen gepland voor deze film.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var screening in screenings)
        {
            <div class="col">
                <div class="card showing-card p-3" @onclick="() => SelectShowing(screening.ScreeningId)">
                    <div class="showing-date mb-2">@FormatDate(screening.StartTimeUtc)</div>
                    <div class="showing-time mb-3">@screening.StartTimeUtc.ToLocalTime().ToString("HH:mm") <small style="font-size:1rem;color:#888;">uur</small></div>
                    <div class="d-flex gap-2 flex-wrap">
                        <span class="badge-hall">Zaal @(screening.Hall?.Number)</span>
                        @if (availableSeats != null && availableSeats.TryGetValue(screening.ScreeningId, out var count))
                        {
                            <span class="seats-badge">@count plaatsen vrij</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid MovieId { get; set; }

    private List<ScreeningResponseDto>? screenings;
    private Dictionary<Guid, int>? availableSeats;
    private string? movieTitle;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var movieTask = Http.GetFromJsonAsync<MovieDetailDto>($"api/movies/{MovieId}");
            var screeningsTask = Http.GetFromJsonAsync<List<ScreeningResponseDto>>($"api/screenings?movieId={MovieId}");
            var seatsTask = Http.GetFromJsonAsync<Dictionary<Guid, int>>($"api/screenings/available-seats?movieId={MovieId}");

            await Task.WhenAll(movieTask, screeningsTask, seatsTask);

            movieTitle = movieTask.Result?.Title;
            screenings = screeningsTask.Result ?? new();
            availableSeats = seatsTask.Result ?? new();
        }
        catch (HttpRequestException)
        {
            errorMessage = "Vertoningen konden niet worden geladen.";
        }
    }

    private string FormatDate(DateTimeOffset date)
    {
        var local = date.ToLocalTime();
        var today = DateTimeOffset.Now.Date;

        if (local.Date == today) return $"Vandaag - {local:d MMMM}";
        if (local.Date == today.AddDays(1)) return $"Morgen - {local:d MMMM}";

        return local.ToString("dddd d MMMM");
    }

    private void SelectShowing(Guid screeningId)
    {
        Navigation.NavigateTo($"/website/tickets/{screeningId}");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/website/home");
    }
}
