@page "/films"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Eerstkomende Films</PageTitle>

<style>
    .movie-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        border-radius: 12px;
        overflow: hidden;
    }
    .movie-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
    }
    .movie-poster {
        height: 400px;
        object-fit: cover;
        width: 100%;
    }
    .movie-poster-placeholder {
        height: 400px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 4rem;
    }
    .screening-item {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 10px 15px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .screening-item:hover {
        background: #e9ecef;
    }
    .hall-badge {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .time-display {
        font-weight: 600;
        color: #333;
    }
    .date-display {
        font-size: 0.85rem;
        color: #666;
    }
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 10px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1.1rem;
    }
    .btn-book {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
        border: none;
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-book:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(238, 90, 36, 0.4);
        color: white;
    }
    .card-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1a1a2e;
    }
</style>

<div class="page-header">
    <h1>Eerstkomende Films</h1>
    <p>Kies een voorstelling en betaal met PIN</p>
</div>

@if (movies == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Laden...</span>
        </div>
        <p class="mt-3 text-muted">Films laden...</p>
    </div>
}
else if (loadError != null)
{
    <div class="alert alert-danger">@loadError</div>
}
else if (movies.Count == 0)
{
    <div class="alert alert-info text-center">
        <h4>Geen films beschikbaar</h4>
        <p>Er zijn momenteel geen films gepland voor de komende 14 dagen.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var movie in movies)
        {
            <div class="col">
                <div class="card movie-card h-100 shadow">
                    @if (!string.IsNullOrEmpty(movie.ImageUrl))
                    {
                        <img src="@movie.ImageUrl" class="movie-poster" alt="@movie.Title poster" />
                    }
                    else
                    {
                        <div class="movie-poster-placeholder">
                            <span>🎬</span>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title mb-3" style="cursor: pointer;" @onclick="() => GoToDetails(movie.MovieId)">@movie.Title</h5>
                        <button class="btn btn-outline-primary btn-sm mb-3" @onclick="() => GoToDetails(movie.MovieId)">
                            Bekijk details & alle zalen
                        </button>
                        <div class="screenings-list">
                            @foreach (var screening in movie.Screenings.Take(5))
                            {
                                <div class="screening-item">
                                    <div>
                                        <div class="time-display">@screening.StartTimeUtc.LocalDateTime.ToString("HH:mm")</div>
                                        <div class="date-display">@screening.StartTimeUtc.LocalDateTime.ToString("ddd dd MMM")</div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="hall-badge">Zaal @screening.HallNumber</span>
                                        <button class="btn btn-book btn-sm"
                                                @onclick="() => SelectScreening(movie, screening)">
                                            Boek
                                        </button>
                                    </div>
                                </div>
                            }
                            @if (movie.Screenings.Count > 5)
                            {
                                <p class="text-muted text-center small mt-2">
                                    + @(movie.Screenings.Count - 5) meer voorstellingen
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ── PIN betaalscherm ── *@
@if (paymentStep && selectedMovie != null && selectedScreening != null)
{
    <div class="ticket-overlay" @onclick="CancelPayment">
        <div class="ticket" @onclick:stopPropagation>
            @if (!string.IsNullOrEmpty(selectedMovie.ImageUrl))
            {
                <img src="@selectedMovie.ImageUrl" style="width: 120px; border-radius: 8px; margin-bottom: 15px;" alt="@selectedMovie.Title" />
            }
            <div class="ticket-header">
                <h2>PIN Betaling</h2>
            </div>
            <hr />
            <table class="ticket-table">
                <tr>
                    <th>Film</th>
                    <td><strong>@selectedMovie.Title</strong></td>
                </tr>
                <tr>
                    <th>Datum</th>
                    <td>@selectedScreening.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td>@selectedScreening.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td><span class="badge bg-primary">Zaal @selectedScreening.HallNumber</span></td>
                </tr>
                <tr>
                    <th>Bedrag</th>
                    <td><strong style="font-size: 1.3rem; color: #28a745;">&#8364;&nbsp;12,50</strong></td>
                </tr>
            </table>
            <hr />
            <div class="alert alert-info text-center py-2 mb-3">
                <small>Alleen PIN-betaling - geen contant geld geaccepteerd</small>
            </div>
            @if (paymentError != null)
            {
                <div class="alert alert-danger py-2">@paymentError</div>
            }
            <div class="no-print d-flex gap-2 justify-content-center">
                <button class="btn btn-success btn-lg" @onclick="ConfirmPinPayment" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span>Verwerken...</span>
                    }
                    else
                    {
                        <span>Betaal met PIN</span>
                    }
                </button>
                <button class="btn btn-outline-secondary" @onclick="CancelPayment" disabled="@isProcessing">
                    Annuleren
                </button>
            </div>
        </div>
    </div>
}

@* ── Ticketscherm (na succesvolle betaling) ── *@
@if (!paymentStep && selectedMovie != null && selectedScreening != null)
{
    <div class="ticket-overlay" @onclick="CloseTicket">
        <div class="ticket" @onclick:stopPropagation style="border: 3px dashed #1b6ec2;">
            <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 15px;">
                @if (!string.IsNullOrEmpty(selectedMovie.ImageUrl))
                {
                    <img src="@selectedMovie.ImageUrl" style="width: 100px; border-radius: 8px; flex-shrink: 0;" alt="@selectedMovie.Title" />
                }
                <div style="text-align: left; flex: 1;">
                    <h3 style="margin: 0 0 5px 0; color: #1a1a2e;">CINEMA TICKET</h3>
                    <p style="margin: 0; color: #666; font-size: 0.9rem;">Bewaar dit ticket goed</p>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                <h4 style="margin: 0; font-size: 1.4rem;">@selectedMovie.Title</h4>
            </div>

            <table class="ticket-table">
                <tr>
                    <th>Datum</th>
                    <td><strong>@selectedScreening.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</strong></td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td><strong style="font-size: 1.3rem; color: #e74c3c;">@selectedScreening.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</strong></td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 8px 20px; border-radius: 25px; font-weight: bold; font-size: 1.1rem;">
                            ZAAL @selectedScreening.HallNumber
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td><span style="color: #27ae60; font-weight: bold;">BETAALD (PIN)</span></td>
                </tr>
            </table>

            @if (printCode != null)
            {
                <div style="background: #f8f9fa; border: 2px solid #dee2e6; border-radius: 8px; padding: 15px; margin: 15px 0; text-align: center;">
                    <p style="margin: 0 0 5px 0; color: #666; font-size: 0.85rem;">TICKETCODE</p>
                    <p style="margin: 0; font-size: 1.8rem; font-weight: bold; letter-spacing: 4px; font-family: monospace;">@printCode</p>
                </div>
            }

            <div style="border-top: 2px dashed #ccc; border-bottom: 2px dashed #ccc; padding: 15px 0; margin: 15px 0;">
                <p class="ticket-barcode" style="margin: 0;">||||| |||| | || ||| || |||| |||||</p>
                <p style="margin: 5px 0 0 0; font-size: 0.75rem; color: #999;">Toon dit ticket bij de ingang</p>
            </div>

            <div class="no-print mt-3 d-flex gap-2 justify-content-center">
                <button class="btn btn-success btn-lg" @onclick="PrintTicket" style="padding: 12px 30px;">
                    Afdrukken
                </button>
                <button class="btn btn-outline-secondary btn-lg" @onclick="CloseTicket">
                    Sluiten
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UpcomingMovieDto>? movies;
    private UpcomingMovieDto? selectedMovie;
    private UpcomingScreeningDto? selectedScreening;
    private bool paymentStep;
    private bool isProcessing;
    private string? paymentError;
    private string? printCode;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movies = await Http.GetFromJsonAsync<List<UpcomingMovieDto>>("api/movies/upcoming");
        }
        catch (Exception ex)
        {
            loadError = $"Kon films niet ophalen: {ex.Message}";
            movies = [];
        }
    }

    private void SelectScreening(UpcomingMovieDto movie, UpcomingScreeningDto screening)
    {
        selectedMovie    = movie;
        selectedScreening = screening;
        paymentStep      = true;
        paymentError     = null;
        printCode        = null;
    }

    private async Task ConfirmPinPayment()
    {
        isProcessing = true;
        paymentError = null;

        try
        {
            var createRequest = new { ScreeningId = selectedScreening!.ScreeningId, TotalAmount = 12.50m };
            var createResponse = await Http.PostAsJsonAsync("api/orders", createRequest);

            if (!createResponse.IsSuccessStatusCode)
            {
                paymentError = "Betaling mislukt. Probeer opnieuw.";
                return;
            }

            var order = await createResponse.Content.ReadFromJsonAsync<OrderDto>();
            if (order != null)
            {
                await Http.PostAsync($"api/orders/{order.OrderId}/pay", null);
                printCode = order.PrintCode;
            }

            paymentStep = false;
        }
        catch
        {
            // API niet beschikbaar – toon ticket zonder code (demo-modus)
            paymentStep = false;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void CancelPayment()
    {
        selectedMovie     = null;
        selectedScreening = null;
        paymentStep       = false;
        paymentError      = null;
    }

    private void CloseTicket()
    {
        selectedMovie     = null;
        selectedScreening = null;
        printCode         = null;
    }

    private async Task PrintTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private void GoToDetails(Guid movieId)
    {
        Navigation.NavigateTo($"/film/{movieId}");
    }
}