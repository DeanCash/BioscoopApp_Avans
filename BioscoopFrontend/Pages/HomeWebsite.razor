@page "/website/home"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Bioscoop - Deze Week</PageTitle>

<style>
    .movie-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
    }
    .movie-card:hover {
        box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
    }
    .movie-poster {
        height: 400px;
        object-fit: cover;
        width: 100%;
    }
    .movie-poster-placeholder {
        height: 400px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 4rem;
    }
    .page-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 40px 0;
        margin: -1rem -1rem 2rem -1rem;
        text-align: center;
    }
    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 10px;
    }
    .page-header p {
        opacity: 0.8;
        font-size: 1.1rem;
    }
    .card-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1a1a2e;
    }
    .btn-details {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-details:hover {
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        color: white;
    }
    .search-filters {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        margin-bottom: 30px;
    }
    .movie-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 4px 10px;
        border-radius: 15px;
        font-size: 0.8rem;
    }
    .age-badge {
        background: #e74c3c;
        color: white;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: bold;
    }
    .btn-secret {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border: none;
        color: white;
        padding: 10px 22px;
        border-radius: 25px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        white-space: nowrap;
    }
    .btn-secret:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(245, 87, 108, 0.5);
        color: white;
    }
    .page-header-inner {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .page-header-text {
        flex: 1;
        text-align: center;
    }
    .page-header-action {
        position: absolute;
        right: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
    }
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
    }
    .modal-box {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        max-width: 460px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    }
    .modal-box h3 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 1rem;
    }
    .modal-box p {
        color: #555;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }
    .modal-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #f5576c;
        margin-bottom: 1.5rem;
    }
    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }
    .btn-select {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border: none;
        color: white;
        padding: 9px 24px;
        border-radius: 25px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-select:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(245, 87, 108, 0.4);
        color: white;
    }
    .btn-cancel {
        background: #e9ecef;
        border: none;
        color: #555;
        padding: 9px 24px;
        border-radius: 25px;
        font-weight: 600;
        transition: background 0.2s;
    }
    .btn-cancel:hover {
        background: #dee2e6;
        color: #333;
    }
</style>

<div class="page-header">
    <div class="page-header-inner">
        <div class="page-header-text">
            <h1>Films Deze Week</h1>
            <p>Kies een film en boek je tickets</p>
        </div>
        <div class="page-header-action">
            <button class="btn btn-secret" @onclick="OpenSecretModal">&#127917; Secret Movie</button>
        </div>
    </div>
</div>

@if (showSecretModal)
{
    <div class="modal-backdrop-custom" @onclick="CloseSecretModal">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Secret Movie</h3>
            <p>
                Benieuwd naar een verrassingfilm? Bij de <strong>Secret Movie</strong> weet je van tevoren niet welke film er gedraaid wordt.
                Laat je verrassen en beleef een unieke bioscoopervaring! De film wordt pas onthuld wanneer je in de zaal zit.
            </p>
            <div class="modal-price">Prijs: &euro;2,50 per ticket</div>
            @if (secretError != null)
            {
                <div class="alert alert-danger py-2">@secretError</div>
            }
            <div class="modal-actions">
                <button class="btn btn-cancel" @onclick="CloseSecretModal" disabled="@secretLoading">Annuleren</button>
                <button class="btn btn-select" @onclick="SelectSecretMovie" disabled="@secretLoading">
                    @if (secretLoading)
                    {
                        <span>Laden...</span>
                    }
                    else
                    {
                        <span>Selecteren</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<div class="search-filters">
    <div class="row g-3 align-items-center">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                    <span>&#128269;</span>
                </span>
                <input type="text" class="form-control border-start-0" placeholder="Zoek op titel..."
                       @bind="searchQuery" @bind:event="oninput" />
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="selectedGenre">
                <option value="">Alle genres</option>
                @foreach (var genre in AvailableGenres)
                {
                    <option value="@genre">@genre</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="selectedAge">
                <option value="0">Alle leeftijden</option>
                <option value="6">6+</option>
                <option value="9">9+</option>
                <option value="12">12+</option>
                <option value="16">16+</option>
                <option value="18">18+</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                Wis filters
            </button>
        </div>
    </div>

    @if (FilteredMovies != null)
    {
        <div class="mt-3 text-muted">
            <small>@FilteredMovies.Count van @movies?.Count films gevonden</small>
        </div>
    }
</div>

@if (movies == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Laden...</span>
        </div>
        <p class="mt-3 text-muted">Films laden...</p>
    </div>
}
else if (loadError != null)
{
    <div class="alert alert-danger">@loadError</div>
}
else if (movies.Count == 0)
{
    <div class="alert alert-info text-center">
        <h4>Geen films beschikbaar</h4>
        <p>Er zijn momenteel geen films gepland voor de komende week.</p>
    </div>
}
else if (FilteredMovies.Count == 0)
{
    <div class="alert alert-info text-center">
        <h4>Geen films gevonden</h4>
        <p>Probeer andere zoektermen of filters.</p>
        <button class="btn btn-primary" @onclick="ClearFilters">Wis alle filters</button>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var movie in FilteredMovies)
        {
            <div class="col">
                <div class="card movie-card h-100 shadow" @onclick="() => GoToDetails(movie.MovieId)">
                    <div style="position: relative;">
                        @if (!string.IsNullOrEmpty(movie.ImageUrl))
                        {
                            <img src="@movie.ImageUrl" class="movie-poster" alt="@movie.Title poster" />
                        }
                        else
                        {
                            <div class="movie-poster-placeholder">
                                <span>&#127916;</span>
                            </div>
                        }
                        <span class="movie-badge">@movie.Genre</span>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="card-title mb-2">@movie.Title</h5>
                        <div class="mb-2">
                            <span class="age-badge">@movie.Age+</span>
                            <small class="text-muted ms-2">@movie.DurationMinutes min</small>
                        </div>
                        <small class="text-muted d-block mb-3">
                            @movie.FirstScreeningAtUtc.LocalDateTime.ToString("ddd d MMM HH:mm")
                        </small>
                        <button class="btn btn-details">
                            Bekijk details
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
private List<UpcomingMovieDto>? movies;
private string? loadError;
private bool showSecretModal;
private bool secretLoading;
private string? secretError;

private string searchQuery = "";
private string selectedGenre = "";
private int selectedAge = 0;

    private List<string> AvailableGenres => movies?
        .Select(m => m.Genre)
        .Where(g => !string.IsNullOrEmpty(g))
        .Distinct()
        .OrderBy(g => g)
        .ToList() ?? new();

    private List<UpcomingMovieDto> FilteredMovies
    {
        get
        {
            if (movies == null) return new();

            var filtered = movies.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                filtered = filtered.Where(m =>
                    m.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrEmpty(selectedGenre))
            {
                filtered = filtered.Where(m => m.Genre == selectedGenre);
            }

            if (selectedAge > 0)
            {
                filtered = filtered.Where(m => m.Age <= selectedAge);
            }

            return filtered.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movies = await Http.GetFromJsonAsync<List<UpcomingMovieDto>>("api/movies/upcoming?daysAhead=7");
        }
        catch (Exception ex)
        {
            loadError = $"Kon films niet ophalen: {ex.Message}";
            movies = [];
        }
    }

    private void ClearFilters()
    {
        searchQuery = "";
        selectedGenre = "";
        selectedAge = 0;
    }

    private void GoToDetails(Guid movieId)
    {
        Navigation.NavigateTo($"/website/showing/{movieId}");
    }

    private void OpenSecretModal() => showSecretModal = true;
    private void CloseSecretModal()
    {
        showSecretModal = false;
        secretError = null;
    }

    private async Task SelectSecretMovie()
    {
        secretLoading = true;
        secretError = null;

        try
        {
            var response = await Http.GetFromJsonAsync<SecretScreeningResponse>("api/movies/secret-screening");
            if (response?.ScreeningId == null)
            {
                secretError = "Geen voorstelling beschikbaar. Probeer later opnieuw.";
                return;
            }

            showSecretModal = false;
            Navigation.NavigateTo($"/website/SelectSeats/{response.ScreeningId}?secret=true");
        }
        catch
        {
            secretError = "Kon de voorstelling niet ophalen. Probeer opnieuw.";
        }
        finally
        {
            secretLoading = false;
        }
    }

    private record SecretScreeningResponse(Guid ScreeningId);
}
