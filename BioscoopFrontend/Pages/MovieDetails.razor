@page "/film/{MovieId:guid}"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(movie?.Title ?? "Film Details")</PageTitle>

<style>
    /* Hero section met backdrop */
    .movie-hero {
        position: relative;
        min-height: 500px;
        margin: -1rem -1rem 0 -1rem;
        overflow: hidden;
    }

    .movie-hero-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-size: cover;
        background-position: center top;
        filter: blur(20px) brightness(0.3);
        transform: scale(1.1);
    }

    .movie-hero-gradient {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to bottom,
            rgba(26, 26, 46, 0.7) 0%,
            rgba(22, 33, 62, 0.9) 70%,
            #16213e 100%);
    }

    .movie-hero-content {
        position: relative;
        z-index: 10;
        padding: 40px 0 60px 0;
    }

    .movie-poster-container {
        position: relative;
    }

    .movie-poster-detail {
        width: 100%;
        max-width: 320px;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        transition: transform 0.3s ease;
    }

    .movie-poster-detail:hover {
        box-shadow: 0 24px 70px rgba(0,0,0,0.6);
    }

    .movie-poster-placeholder {
        width: 100%;
        max-width: 320px;
        height: 480px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        margin: 0 auto;
    }

    .movie-info {
        color: white;
        padding-left: 40px;
    }

    .btn-back {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 10px 24px;
        border-radius: 30px;
        margin-bottom: 30px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        font-weight: 500;
    }

    .btn-back:hover {
        background: rgba(255,255,255,0.2);
        color: white;
    }

    .movie-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 20px;
        text-shadow: 0 4px 20px rgba(0,0,0,0.3);
        line-height: 1.1;
    }

    .movie-meta {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .meta-badge {
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        padding: 10px 20px;
        border-radius: 30px;
        font-size: 0.95rem;
        font-weight: 500;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .meta-badge.age-rating {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        border: none;
    }

    .meta-badge.duration {
        background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        border: none;
    }

    .movie-description {
        font-size: 1.15rem;
        line-height: 1.8;
        opacity: 0.9;
        max-width: 600px;
    }

    /* Screenings section */
    .screenings-section {
        background: linear-gradient(180deg, #16213e 0%, #1a1a2e 100%);
        padding: 50px 0 80px 0;
        margin: 0 -1rem -1rem -1rem;
        min-height: 400px;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 700;
        color: white;
        margin-bottom: 35px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .section-title::before {
        content: '';
        width: 5px;
        height: 35px;
        background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
        border-radius: 3px;
    }

    .screening-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 25px 30px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.3s ease;
    }

    .screening-card:hover {
        background: rgba(255,255,255,0.1);
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    }

    .screening-datetime {
        display: flex;
        flex-direction: column;
        min-width: 200px;
    }

    .screening-date {
        font-size: 1rem;
        font-weight: 500;
        color: rgba(255,255,255,0.7);
        text-transform: capitalize;
    }

    .screening-time {
        font-size: 2rem;
        font-weight: 800;
        color: white;
        letter-spacing: -1px;
    }

    .screening-hall {
        text-align: center;
        min-width: 160px;
    }

    .hall-badge {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 24px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 1rem;
        display: inline-block;
        margin-bottom: 8px;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .seats-info {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
    }

    .seats-available {
        color: #2ecc71;
        font-weight: 700;
    }

    .seats-limited {
        color: #f39c12;
        font-weight: 700;
    }

    .seats-full {
        color: #e74c3c;
        font-weight: 700;
    }

    .btn-book {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
        border: none;
        color: white;
        padding: 14px 35px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(238, 90, 36, 0.4);
    }

    .btn-book:hover {
        box-shadow: 0 8px 25px rgba(238, 90, 36, 0.5);
        color: white;
    }

    .btn-book:disabled {
        background: linear-gradient(135deg, #636e72 0%, #2d3436 100%);
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .no-screenings {
        text-align: center;
        padding: 60px 40px;
        background: rgba(255,255,255,0.05);
        border-radius: 16px;
        color: rgba(255,255,255,0.7);
        border: 1px solid rgba(255,255,255,0.1);
    }

    .no-screenings h4 {
        color: white;
        margin-bottom: 10px;
    }

    /* Ticket overlay styling */
    .ticket-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.8);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 20px;
    }

    .ticket {
        background: white;
        border-radius: 20px;
        padding: 35px;
        max-width: 450px;
        width: 100%;
        box-shadow: 0 25px 80px rgba(0,0,0,0.5);
        text-align: center;
    }

    .ticket-header h2 {
        color: #1a1a2e;
        font-weight: 700;
        margin: 0;
    }

    .ticket-table {
        width: 100%;
        margin: 20px 0;
        text-align: left;
    }

    .ticket-table th {
        color: #666;
        font-weight: 500;
        padding: 10px 0;
        width: 100px;
        vertical-align: top;
    }

    .ticket-table td {
        color: #1a1a2e;
        padding: 10px 0;
    }

    .ticket-barcode {
        font-family: 'Libre Barcode 39', monospace;
        font-size: 3rem;
        letter-spacing: 5px;
        color: #1a1a2e;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .movie-hero {
            min-height: auto;
        }

        .movie-info {
            padding-left: 0;
            padding-top: 30px;
            text-align: center;
        }

        .movie-title {
            font-size: 2rem;
        }

        .movie-meta {
            justify-content: center;
        }

        .movie-description {
            text-align: left;
        }

        .screening-card {
            flex-direction: column;
            gap: 20px;
            text-align: center;
        }

        .screening-datetime {
            min-width: auto;
            align-items: center;
        }

        .ticket {
            padding: 25px;
        }
    }

    /* Loading animation */
    .loading-container {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        margin: -1rem;
    }

    .loading-spinner {
        width: 60px;
        height: 60px;
        border: 4px solid rgba(255,255,255,0.1);
        border-left-color: #667eea;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .loading-text {
        color: rgba(255,255,255,0.7);
        margin-top: 20px;
        font-size: 1.1rem;
    }
</style>

@if (movie == null)
{
    <div class="loading-container">
        <div class="loading-spinner"></div>
        <p class="loading-text">Film laden...</p>
    </div>
}
else
{
    <div class="movie-hero">
        @if (!string.IsNullOrEmpty(movie.ImageUrl))
        {
            <div class="movie-hero-backdrop" style="background-image: url('@movie.ImageUrl');"></div>
        }
        <div class="movie-hero-gradient"></div>

        <div class="movie-hero-content">
            <div class="container">
                <button class="btn btn-back" @onclick="GoBack">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    Terug naar overzicht
                </button>

                <div class="row align-items-center">
                    <div class="col-lg-4 col-md-5 text-center mb-4 mb-md-0">
                        @if (!string.IsNullOrEmpty(movie.ImageUrl))
                        {
                            <img src="@movie.ImageUrl" class="movie-poster-detail" alt="@movie.Title poster" />
                        }
                        else
                        {
                            <div class="movie-poster-placeholder">
                                <span style="font-size: 5rem; opacity: 0.8;">🎬</span>
                            </div>
                        }
                    </div>
                    <div class="col-lg-8 col-md-7 movie-info">
                        <h1 class="movie-title">@movie.Title</h1>
                        <div class="movie-meta">
                            <span class="meta-badge duration">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px; vertical-align: -2px;">
                                    <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                                </svg>
                                @movie.DurationMinutes min
                            </span>
                            <span class="meta-badge age-rating">@movie.Age+</span>
                            <span class="meta-badge">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px; vertical-align: -2px;">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                                @movie.Screenings.Count voorstellingen
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(movie.Description))
                        {
                            <p class="movie-description">@movie.Description</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="screenings-section">
        <div class="container">
            <h2 class="section-title">Voorstellingen & Zalen</h2>

            @if (movie.Screenings.Count == 0)
            {
                <div class="no-screenings">
                    <h4>Geen voorstellingen gepland</h4>
                    <p>Er zijn momenteel geen voorstellingen gepland voor deze film.</p>
                </div>
            }
            else
            {
                @foreach (var screening in movie.Screenings)
                {
                    <div class="screening-card">
                        <div class="screening-datetime">
                            <span class="screening-date">@screening.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM")</span>
                            <span class="screening-time">@screening.StartTimeUtc.LocalDateTime.ToString("HH:mm")</span>
                        </div>
                        <div class="screening-hall">
                            <span class="hall-badge">@screening.HallName</span>
                            <div class="seats-info">
                                @{
                                    var percentage = screening.TotalSeats > 0
                                        ? (screening.AvailableSeats * 100 / screening.TotalSeats)
                                        : 0;
                                    var seatsClass = percentage > 50 ? "seats-available"
                                        : percentage > 10 ? "seats-limited"
                                        : "seats-full";
                                }
                                <span class="@seatsClass">@screening.AvailableSeats</span> / @screening.TotalSeats stoelen
                            </div>
                        </div>
                        <div>
                            <button class="btn btn-book"
                                    @onclick="() => SelectScreening(screening)"
                                    disabled="@(screening.AvailableSeats == 0)">
                                @(screening.AvailableSeats == 0 ? "Uitverkocht" : "Boek nu")
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@* ── PIN betaalscherm ── *@
@if (paymentStep && movie != null && selectedScreening != null)
{
    <div class="ticket-overlay" @onclick="CancelPayment">
        <div class="ticket" @onclick:stopPropagation>
            @if (!string.IsNullOrEmpty(movie.ImageUrl))
            {
                <img src="@movie.ImageUrl" style="width: 140px; border-radius: 12px; margin-bottom: 20px; box-shadow: 0 8px 25px rgba(0,0,0,0.2);" alt="@movie.Title" />
            }
            <div class="ticket-header">
                <h2>PIN Betaling</h2>
            </div>
            <hr style="border-color: #eee; margin: 20px 0;" />
            <table class="ticket-table">
                <tr>
                    <th>Film</th>
                    <td><strong>@movie.Title</strong></td>
                </tr>
                <tr>
                    <th>Datum</th>
                    <td>@selectedScreening.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td>@selectedScreening.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td><span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 6px 14px; border-radius: 20px; font-weight: 600; font-size: 0.9rem;">@selectedScreening.HallName</span></td>
                </tr>
                <tr>
                    <th>Bedrag</th>
                    <td><strong style="font-size: 1.5rem; color: #27ae60;">€ 12,50</strong></td>
                </tr>
            </table>
            <hr style="border-color: #eee; margin: 20px 0;" />
            <div style="background: #e3f2fd; border-radius: 10px; padding: 12px; margin-bottom: 20px;">
                <small style="color: #1976d2;">Alleen PIN-betaling - geen contant geld</small>
            </div>
            @if (paymentError != null)
            {
                <div class="alert alert-danger py-2 mb-3">@paymentError</div>
            }
            <div class="d-flex gap-3 justify-content-center">
                <button class="btn btn-success btn-lg" style="padding: 14px 40px; border-radius: 30px; font-weight: 600;" @onclick="ConfirmPinPayment" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span>Verwerken...</span>
                    }
                    else
                    {
                        <span>Betaal met PIN</span>
                    }
                </button>
                <button class="btn btn-outline-secondary btn-lg" style="padding: 14px 30px; border-radius: 30px;" @onclick="CancelPayment" disabled="@isProcessing">
                    Annuleren
                </button>
            </div>
        </div>
    </div>
}

@* ── Ticketscherm (na succesvolle betaling) ── *@
@if (!paymentStep && selectedScreening != null && printCode != null)
{
    <div class="ticket-overlay" @onclick="CloseTicket">
        <div class="ticket" @onclick:stopPropagation style="border: 4px dashed #667eea;">
            <div style="display: flex; align-items: flex-start; gap: 20px; margin-bottom: 20px;">
                @if (!string.IsNullOrEmpty(movie?.ImageUrl))
                {
                    <img src="@movie.ImageUrl" style="width: 100px; border-radius: 10px; flex-shrink: 0; box-shadow: 0 4px 15px rgba(0,0,0,0.2);" alt="@movie.Title" />
                }
                <div style="text-align: left; flex: 1;">
                    <h3 style="margin: 0 0 5px 0; color: #1a1a2e; font-weight: 800;">CINEMA TICKET</h3>
                    <p style="margin: 0; color: #666; font-size: 0.9rem;">Bewaar dit ticket goed</p>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 18px; border-radius: 12px; margin-bottom: 20px;">
                <h4 style="margin: 0; font-size: 1.5rem; font-weight: 700;">@movie?.Title</h4>
            </div>

            <table class="ticket-table">
                <tr>
                    <th>Datum</th>
                    <td><strong>@selectedScreening.StartTimeUtc.LocalDateTime.ToString("dddd dd MMMM yyyy")</strong></td>
                </tr>
                <tr>
                    <th>Aanvang</th>
                    <td><strong style="font-size: 1.4rem; color: #e74c3c;">@selectedScreening.StartTimeUtc.LocalDateTime.ToString("HH:mm") uur</strong></td>
                </tr>
                <tr>
                    <th>Zaal</th>
                    <td>
                        <span style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 10px 22px; border-radius: 25px; font-weight: bold; font-size: 1.1rem; display: inline-block;">
                            @selectedScreening.HallName.ToUpper()
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td><span style="color: #27ae60; font-weight: bold; font-size: 1.1rem;">BETAALD (PIN)</span></td>
                </tr>
            </table>

            <div style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border: 2px solid #dee2e6; border-radius: 12px; padding: 20px; margin: 20px 0; text-align: center;">
                <p style="margin: 0 0 8px 0; color: #666; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Ticketcode</p>
                <p style="margin: 0; font-size: 2rem; font-weight: 800; letter-spacing: 6px; font-family: monospace; color: #1a1a2e;">@printCode</p>
            </div>

            <div style="border-top: 3px dashed #ccc; border-bottom: 3px dashed #ccc; padding: 18px 0; margin: 20px 0;">
                <p class="ticket-barcode" style="margin: 0; font-size: 2.5rem;">||||| |||| | || ||| || |||| |||||</p>
                <p style="margin: 8px 0 0 0; font-size: 0.8rem; color: #999;">Toon dit ticket bij de ingang</p>
            </div>

            <div class="d-flex gap-3 justify-content-center mt-4">
                <button class="btn btn-success btn-lg" style="padding: 14px 40px; border-radius: 30px; font-weight: 600;" @onclick="PrintTicket">
                    Afdrukken
                </button>
                <button class="btn btn-outline-primary btn-lg" style="padding: 14px 30px; border-radius: 30px;" @onclick="OpenPrintPage">
                    Naar printpagina
                </button>
                <button class="btn btn-outline-secondary btn-lg" style="padding: 14px 30px; border-radius: 30px;" @onclick="CloseTicket">
                    Sluiten
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid MovieId { get; set; }

    private MovieDetailsDto? movie;
    private ScreeningWithHallDto? selectedScreening;
    private bool paymentStep;
    private bool isProcessing;
    private string? paymentError;
    private string? printCode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movie = await Http.GetFromJsonAsync<MovieDetailsDto>($"api/movies/{MovieId}/details");
        }
        catch
        {
            // API niet beschikbaar
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/kiosk/home");
    }

    private void SelectScreening(ScreeningWithHallDto screening)
    {
        selectedScreening = screening;
        paymentStep = true;
        paymentError = null;
        printCode = null;
    }

    private async Task ConfirmPinPayment()
    {
        isProcessing = true;
        paymentError = null;

        try
        {
            var createRequest = new { ScreeningId = selectedScreening!.ScreeningId, TotalAmount = 12.50m };
            var createResponse = await Http.PostAsJsonAsync("api/orders", createRequest);

            if (!createResponse.IsSuccessStatusCode)
            {
                paymentError = "Betaling mislukt. Probeer opnieuw.";
                return;
            }

            var order = await createResponse.Content.ReadFromJsonAsync<OrderDto>();
            if (order != null)
            {
                await Http.PostAsync($"api/orders/{order.OrderId}/pay", null);
                printCode = order.PrintCode;
            }

            paymentStep = false;
        }
        catch
        {
            // API niet beschikbaar – toon ticket zonder code (demo-modus)
            printCode = "DEMO-" + new Random().Next(1000, 9999);
            paymentStep = false;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void CancelPayment()
    {
        selectedScreening = null;
        paymentStep = false;
        paymentError = null;
    }

    private void CloseTicket()
    {
        selectedScreening = null;
        printCode = null;
    }

    private async Task PrintTicket()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}